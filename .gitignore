# Frontend (Node.js/Vite)
Frontend/node_modules/
Frontend/dist/
Frontend/dist-ssr/
Frontend/*.local
Frontend/.env
Frontend/.env.*
!Frontend/.env.example
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backend (Python/FastAPI)
Backend/venv/
Backend/__pycache__/
Backend/**/*.py[cod]
*$py.class
Backend/.pytest_cache/
Backend/.env
Backend/**/*.log

# Datasets (Ignoring large CSV files containing the 5.25M records to prevent Git bloat)
Backend/data/raw/*.csv
Backend/data/processed/*.csv
Backend/data/**/*.lock
Backend/data/**/.~lock*

# IDE / OS Specific
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.log
